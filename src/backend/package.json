{
  "name": "@mandi/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/master.prisma",
    "db:migrate:master": "prisma migrate dev --schema=prisma/master.prisma",
    "db:migrate:tenant": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy:master": "prisma migrate deploy --schema=prisma/master.prisma",
    "db:migrate:deploy:tenant": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:studio:master": "prisma studio --schema=prisma/master.prisma",
    "db:studio:tenant": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@mandi/shared": "*",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
