# ── Master database (platform registry: tenants + superusers) ────
MASTER_DATABASE_URL="postgresql://postgres:password@localhost:5432/mandi_master"

# ── Tenant database placeholder (used only for prisma db push during provisioning) ──
TENANT_DATABASE_URL="postgresql://postgres:password@localhost:5432/mandi_tenant_example"

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
# ALLOWED_ORIGINS="https://your-frontend-domain.com"

