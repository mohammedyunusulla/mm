// Per-tenant database schema — one copy of this DB per mandi.
// Connection: TENANT_DATABASE_URL (set per-tenant at provision time)
// Run: npx prisma generate --schema=prisma/schema.prisma
//      npx prisma migrate dev --schema=prisma/schema.prisma --name init

generator client {
  provider = "prisma-client-js"
  // default output – used by the cached per-tenant PrismaClient instances
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

// ── USER ─────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
}

// ── CLIENT ───────────────────────────────────────────────────────
model Client {
  id             String     @id @default(uuid())
  name           String
  phone          String
  address        String
  type           ClientType
  notes          String?
  balanceDue     Decimal    @default(0) @db.Decimal(12, 2)
  advanceBalance Decimal    @default(0) @db.Decimal(12, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  transactions    Transaction[]
  advancePayments AdvancePayment[]

  @@index([type])
}

enum ClientType {
  BUYER
  SELLER
}

// ── ADVANCE PAYMENT ──────────────────────────────────────────────
model AdvancePayment {
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber String
  amount        Decimal  @db.Decimal(12, 2)
  note          String?
  date          DateTime
  createdAt     DateTime @default(now())

  @@index([clientId])
}

// ── TRANSACTION ──────────────────────────────────────────────────
model Transaction {
  id          String          @id @default(uuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  type        TransactionType
  totalAmount Decimal         @db.Decimal(12, 2)
  paidAmount  Decimal         @db.Decimal(12, 2)
  balanceDue  Decimal         @db.Decimal(12, 2)
  notes       String?
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items TransactionItem[]

  @@index([clientId])
  @@index([type])
  @@index([date])
}

enum TransactionType {
  PURCHASE
  SALE
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  itemName      String
  quantity      Decimal     @db.Decimal(10, 3)
  unit          String
  pricePerUnit  Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
}

// ── EXPENSE ──────────────────────────────────────────────────────
model Expense {
  id          String          @id @default(uuid())
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
}

enum ExpenseCategory {
  LABOUR
  TRANSPORT
  RENT
  UTILITIES
  MAINTENANCE
  OTHER
}

// ── INVOICE COUNTER ──────────────────────────────────────────────
// Keyed on yearMonth – one row per month, auto-increments
model InvoiceCounter {
  yearMonth String @id   // "202603"
  counter   Int    @default(0)
}

